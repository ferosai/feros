# Root .env — used by docker compose up -d
# Copy to .env and customise.
# Local development only. Used by docker compose variable substitution.
# Not used when running studio/api or voice/server directly.

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=ferosdev
POSTGRES_DB=voice_agent

# ── Shared across services ───────────────────────────────────
# Must match between studio-api and voice-server.
AUTH__SECRET_KEY=change-me-in-production

# Override the full connection string (optional — built automatically
# from POSTGRES_PASSWORD and POSTGRES_DB when omitted).
# DATABASE__URL=postgresql://voice-agent-os:ferosdev@db:5432/voice_agent
